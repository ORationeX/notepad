# ##############################################################################
# Git Ignore Settings for Developer Utility Suite
# ##############################################################################

# ------------------------------------------------------------------------------
# 1. OS & System Files (운영체제 및 시스템 생성 파일)
# ------------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------------------------------------------------------
# 2. IDE & Editors (개발 도구 및 에디터 설정)
# ------------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
*.code-workspace
.history/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ------------------------------------------------------------------------------
# 3. Node & Javascript (Node.js 의존성 및 빌드 결과물)
# ------------------------------------------------------------------------------
node_modules/
jspm_packages/
.npm/
.eslintcache
.parcel-cache/
.turbo/

# 빌드 및 컴파일 결과 파일
dist/
out/
build/
bin/
tsc-output.txt
*-output.txt

# ------------------------------------------------------------------------------
# 4. Python (파이썬 가상환경 및 캐시 파일)
# ------------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.poetry/
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# 5. Environment Variables & Credentials (환경 설정 및 보안 정보)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.pfx

# ------------------------------------------------------------------------------
# 6. Logs & Temporary Files (로그 및 임시 파일)
# ------------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
build_log.txt
tmp/
temp/
